# ── Server ──────────────────────────────────────────────────────────
# Port the Colyseus WebSocket + HTTP server listens on
PORT=2567

# Log level: error | warn | info | debug
LOG_LEVEL=info

# Internal TTS API base URL used by News Broadcast on the server.
# In Docker Compose this is wired automatically to the tts-api service.
# Set this to http://localhost:8090 when running the TTS stack outside Compose.
TTS_API_URL=

# ── Client ──────────────────────────────────────────────────────────
# Unified client Vite dev server port
CLIENT_PORT=5173

# WebSocket URL the browser client connects to.
# During local dev this points to the server above.
VITE_SERVER_URL=ws://localhost:2567

# Runtime WebSocket URL injected into the containerized client via /config.js
GAMMA_SERVER_URL=ws://localhost:2567

# ── Sessions ────────────────────────────────────────────────────────
# How long (seconds) a disconnected player slot is held open for reconnect
RECONNECT_GRACE_SECONDS=30

# ── News Broadcast TTS stack ────────────────────────────────────────
# Redis queue + job metadata store
REDIS_URL=redis://localhost:6379/0
TTS_REDIS_KEY_PREFIX=gamma:tts

# SeaweedFS / S3-compatible artifact storage.
# In local Compose, these values are also used as the SeaweedFS S3 credentials.
MINIO_ENDPOINT=localhost:8333
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=gamma
MINIO_SECRET_KEY=gammalocal
MINIO_BUCKET_NAME=gamma-tts-artifacts

# API readiness and retention behavior
TTS_REQUIRE_WORKER_READY=true
TTS_REQUIRE_CUSTOM_VOICE_PACK=false
TTS_RETENTION=2h
TTS_CLEANUP_INTERVAL=10m
TTS_LEASE_RECOVERY_INTERVAL=15s

# Worker runtime configuration
# Compose defaults to a persistent container volume at /tmp/tts-models.
TTS_MODEL_DIR=/tmp/tts-models
TTS_MODEL_VERSION=OpenMOSS-Team/MOSS-TTS-Nano-100M-ONNX
TTS_MAX_RETRIES=3
TTS_WARMUP_ENABLED=false
TTS_CPU_THREADS=2
TTS_LOG_LEVEL=INFO
TTS_MP3_BITRATE_KBPS=128
TTS_WORKER_HEARTBEAT_INTERVAL=10s
TTS_WORKER_HEARTBEAT_MAX_AGE=45s
TTS_WORKER_LEASE_DURATION=90s
TTS_WORKER_POLL_INTERVAL=1s
TTS_WORKER_BUSY_POLL_INTERVAL=250ms
TTS_WORKER_QUEUE_CLAIM_BATCH_SIZE=10

# ── Klipy GIF API ──────────────────────────────────────────────────
# API key for Klipy GIF search (used by Audio Overlay game)
# Get a key at https://klipy.com
KLIPY_API_KEY=

# ── OpenTelemetry ──────────────────────────────────────────────────
# Set to "false" to disable all OpenTelemetry tracing/metrics
OTEL_ENABLED=true

# OTLP collector endpoint (traces + metrics)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Service name reported to the collector
OTEL_SERVICE_NAME=gamma-server

# ── Docker / Compose ────────────────────────────────────────────────
# Set to your registry prefix when pushing images
DOCKER_REGISTRY=ghcr.io/gamma

# ── Kubernetes / Helm (operator deploy only) ────────────────────────
# Namespace for the operator hub component
OPERATOR_NAMESPACE=gamma-system
